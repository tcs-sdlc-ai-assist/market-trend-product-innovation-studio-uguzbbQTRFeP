# =============================================================================
# Market Trend Innovation Studio — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# All client-side variables MUST be prefixed with VITE_ to be exposed to the app.
# Access them in code via import.meta.env.VITE_*
# =============================================================================

# Application title displayed in the browser tab and header
VITE_APP_TITLE=Market Trend Innovation Studio

# Application version string (semver recommended)
VITE_APP_VERSION=1.0.0

# Brand mode controls theming and logo assets
# Options:
#   placeholder — generic/unbranded styling (default for development)
#   givaudan    — Givaudan-branded colors, logos, and typography
VITE_BRAND_MODE=placeholder